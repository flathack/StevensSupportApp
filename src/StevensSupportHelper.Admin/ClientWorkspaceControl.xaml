<UserControl x:Class="StevensSupportHelper.Admin.ClientWorkspaceControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Padding="16"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock x:Name="ClientNameTextBlock"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Text="Client" />
                    <TextBlock x:Name="ClientSummaryTextBlock"
                               Margin="0,6,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextWrapping="Wrap"
                               Text="-" />

                    <TextBlock Margin="0,18,0,8"
                               FontWeight="SemiBold"
                               Text="Actions" />

                    <UniformGrid Columns="2">
                        <Button x:Name="RequestSupportButton"
                                Margin="0,0,8,8"
                                Padding="12,8"
                                Tag="request-support"
                                Click="ActionButton_OnClick"
                                Content="Request Support" />
                        <Button x:Name="ConnectButton"
                                Margin="0,0,0,8"
                                Padding="12,8"
                                Tag="connect"
                                Click="ActionButton_OnClick"
                                Content="Connect" />
                        <Button x:Name="RdpConnectButton"
                                Margin="0,0,8,8"
                                Padding="12,8"
                                Tag="rdp"
                                Click="ActionButton_OnClick"
                                Content="RDP Connect" />
                        <Button x:Name="RustDeskButton"
                                Margin="0,0,0,8"
                                Padding="12,8"
                                Tag="rustdesk"
                                Click="ActionButton_OnClick"
                                Content="RustDesk" />
                        <Button x:Name="PowerShellConsoleButton"
                                Margin="0,0,8,8"
                                Padding="12,8"
                                Tag="ps-console"
                                Click="ActionButton_OnClick"
                                Content="PS Console" />
                        <Button x:Name="DashboardButton"
                                Margin="0,0,0,8"
                                Padding="12,8"
                                Tag="dashboard"
                                Click="ActionButton_OnClick"
                                Content="Dashboard" />
                        <Button x:Name="FilesButton"
                                Margin="0,0,8,8"
                                Padding="12,8"
                                Tag="files"
                                Click="ActionButton_OnClick"
                                Content="Files" />
                        <Button x:Name="TasksButton"
                                Margin="0,0,0,8"
                                Padding="12,8"
                                Tag="tasks"
                                Click="ActionButton_OnClick"
                                Content="Tasks" />
                        <Button x:Name="ServicesButton"
                                Margin="0,0,8,8"
                                Padding="12,8"
                                Tag="services"
                                Click="ActionButton_OnClick"
                                Content="Services" />
                        <Button x:Name="SoftwareButton"
                                Margin="0,0,0,8"
                                Padding="12,8"
                                Tag="software"
                                Click="ActionButton_OnClick"
                                Content="Software" />
                        <Button x:Name="RegistryButton"
                                Margin="0,0,8,8"
                                Padding="12,8"
                                Tag="registry"
                                Click="ActionButton_OnClick"
                                Content="Registry" />
                        <Button x:Name="PowerOptionsButton"
                                Margin="0,0,8,8"
                                Padding="12,8"
                                Tag="power"
                                Click="ActionButton_OnClick"
                                Content="Power" />
                        <Button x:Name="WindowsUpdatesButton"
                                Margin="0,0,0,8"
                                Padding="12,8"
                                Tag="windows-updates"
                                Click="ActionButton_OnClick"
                                Content="Windows Updates" />
                        <Button x:Name="ChatButton"
                                Margin="0,0,8,8"
                                Padding="12,8"
                                Tag="chat"
                                Click="ActionButton_OnClick"
                                Content="Chat" />
                        <Button x:Name="RemoteActionButton"
                                Margin="0,0,0,8"
                                Padding="12,8"
                                Tag="remote-action"
                                Click="ActionButton_OnClick"
                                Content="Remote Actions" />
                        <Button x:Name="ScreenshotButton"
                                Margin="0,0,8,8"
                                Padding="12,8"
                                Tag="screenshot"
                                Click="ActionButton_OnClick"
                                Content="Screenshot" />
                        <Button x:Name="RebootButton"
                                Margin="0,0,0,8"
                                Padding="12,8"
                                Tag="reboot"
                                Click="ActionButton_OnClick"
                                Content="Reboot" />
                        <Button x:Name="ShutdownButton"
                                Margin="0,0,8,8"
                                Padding="12,8"
                                Tag="shutdown"
                                Click="ActionButton_OnClick"
                                Content="Shutdown" />
                        <Button x:Name="EndSessionButton"
                                Margin="0,0,8,8"
                                Padding="12,8"
                                Tag="end-session"
                                Click="ActionButton_OnClick"
                                Content="End Session" />
                        <Button x:Name="EditClientButton"
                                Margin="0,0,0,8"
                                Padding="12,8"
                                Tag="edit-client"
                                Click="ActionButton_OnClick"
                                Content="Edit Client" />
                    </UniformGrid>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <TabControl x:Name="WorkspaceTabControl"
                    Grid.Column="2"
                    Background="{DynamicResource SurfaceBackgroundBrush}" />
    </Grid>
</UserControl>
