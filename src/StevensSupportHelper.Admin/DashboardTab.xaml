<UserControl x:Class="StevensSupportHelper.Admin.DashboardTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12">
            <DockPanel>
                <TextBlock FontSize="20"
                           FontWeight="SemiBold"
                           Text="Client Dashboard" />
                <Button x:Name="RefreshButton"
                        DockPanel.Dock="Right"
                        Padding="12,6"
                        Click="RefreshButton_OnClick"
                        Content="Refresh" />
            </DockPanel>

            <UniformGrid Margin="0,14,0,0"
                         Columns="4">
                <Border Margin="0,0,10,10"
                        Padding="12"
                        Background="{DynamicResource PanelBackgroundBrush}"
                        BorderBrush="{DynamicResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="CPU"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                        <TextBlock x:Name="CpuTextBlock"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Text="-" />
                    </StackPanel>
                </Border>
                <Border Margin="0,0,10,10"
                        Padding="12"
                        Background="{DynamicResource PanelBackgroundBrush}"
                        BorderBrush="{DynamicResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="RAM"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                        <TextBlock x:Name="RamTextBlock"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Text="-" />
                    </StackPanel>
                </Border>
                <Border Margin="0,0,10,10"
                        Padding="12"
                        Background="{DynamicResource PanelBackgroundBrush}"
                        BorderBrush="{DynamicResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="Battery"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                        <TextBlock x:Name="BatteryTextBlock"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Text="-" />
                    </StackPanel>
                </Border>
                <Border Margin="0,0,0,10"
                        Padding="12"
                        Background="{DynamicResource PanelBackgroundBrush}"
                        BorderBrush="{DynamicResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="Uptime"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                        <TextBlock x:Name="UptimeTextBlock"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Text="-" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Padding="12"
                    Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <StackPanel>
                    <TextBlock FontSize="16"
                               FontWeight="SemiBold"
                               Text="Memory Usage" />
                    <TextBlock x:Name="MemorySummaryTextBlock"
                               Margin="0,6,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Text="-" />
                    <Grid Margin="0,10,0,0"
                          Height="14">
                        <Border Background="#233047"
                                CornerRadius="7" />
                        <Border x:Name="MemoryBar"
                                HorizontalAlignment="Left"
                                Background="#10B981"
                                CornerRadius="7" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Margin="0,12,0,0"
                    Padding="12"
                    Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <StackPanel>
                    <TextBlock FontSize="16"
                               FontWeight="SemiBold"
                               Text="Disk Usage" />
                    <ItemsControl x:Name="DiskItemsControl"
                                  Margin="0,10,0,0" />
                </StackPanel>
            </Border>

            <TextBlock x:Name="StatusTextBlock"
                       Margin="0,14,0,0"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Text="Ready" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
