<UserControl x:Class="StevensSupportHelper.Admin.FileExplorerTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       Text="Local &lt;-&gt; Remote Explorer" />
            <Button x:Name="RefreshButton"
                    Grid.Column="1"
                    Margin="12,0,0,0"
                    Padding="14,8"
                    Content="Refresh"
                    Click="RefreshButton_OnClick" />
            <Button x:Name="UploadButton"
                    Grid.Column="2"
                    Margin="12,0,0,0"
                    Padding="14,8"
                    Content="Upload ->"
                    Click="UploadButton_OnClick" />
            <Button x:Name="DownloadButton"
                    Grid.Column="3"
                    Margin="12,0,0,0"
                    Padding="14,8"
                    Content="&lt;- Download"
                    Click="DownloadButton_OnClick" />
            <Button x:Name="NewFolderButton"
                    Grid.Column="4"
                    Margin="12,0,0,0"
                    Padding="14,8"
                    Content="New Folder"
                    Click="NewFolderButton_OnClick" />
            <Button x:Name="DeleteButton"
                    Grid.Column="5"
                    Margin="12,0,0,0"
                    Padding="14,8"
                    Content="Delete"
                    Click="DeleteButton_OnClick" />
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="10"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Background="{DynamicResource PanelBackgroundBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0"
                          Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="LocalPathTextBox"
                                 Height="34"
                                 VerticalContentAlignment="Center" />
                        <Button x:Name="LocalUpButton"
                                Grid.Column="1"
                                Margin="10,0,0,0"
                                Padding="12,8"
                                Content="Up"
                                Click="LocalUpButton_OnClick" />
                        <Button x:Name="LocalBrowseButton"
                                Grid.Column="2"
                                Margin="10,0,0,0"
                                Padding="12,8"
                                Content="Browse"
                                Click="LocalBrowseButton_OnClick" />
                    </Grid>

                    <DataGrid x:Name="LocalEntriesDataGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              RowHeight="38"
                              MouseDoubleClick="LocalEntriesDataGrid_OnMouseDoubleClick"
                              PreviewMouseRightButtonDown="EntriesDataGrid_OnPreviewMouseRightButtonDown"
                              SelectionChanged="EntriesDataGrid_OnSelectionChanged">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="10,6" />
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Open"
                                          Click="LocalOpenMenuItem_OnClick" />
                                <MenuItem Header="Upload to Remote"
                                          Click="LocalUploadMenuItem_OnClick" />
                                <Separator />
                                <MenuItem Header="Copy Path"
                                          Click="LocalCopyPathMenuItem_OnClick" />
                                <MenuItem Header="Refresh"
                                          Click="LocalRefreshMenuItem_OnClick" />
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header=""
                                                    Width="52"
                                                    IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="18"
                                                   Text="{Binding EntryIcon}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*" />
                            <DataGridTextColumn Header="Type" Binding="{Binding EntryType}" Width="110" />
                            <DataGridTextColumn Header="Size" Binding="{Binding SizeText}" Width="110" />
                            <DataGridTextColumn Header="Last Write (UTC)" Binding="{Binding LastWriteTimeUtc}" Width="170" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Padding="10"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Background="{DynamicResource SurfaceBackgroundBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0"
                          Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="RemotePathTextBox"
                                 Height="34"
                                 VerticalContentAlignment="Center" />
                        <Button x:Name="RemoteUpButton"
                                Grid.Column="1"
                                Margin="10,0,0,0"
                                Padding="12,8"
                                Content="Up"
                                Click="RemoteUpButton_OnClick" />
                        <Button x:Name="RemoteRootButton"
                                Grid.Column="2"
                                Margin="10,0,0,0"
                                Padding="12,8"
                                Content="Drives"
                                Click="RemoteRootButton_OnClick" />
                    </Grid>

                    <DataGrid x:Name="RemoteEntriesDataGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              RowHeight="38"
                              MouseDoubleClick="RemoteEntriesDataGrid_OnMouseDoubleClick"
                              PreviewMouseRightButtonDown="EntriesDataGrid_OnPreviewMouseRightButtonDown"
                              SelectionChanged="EntriesDataGrid_OnSelectionChanged">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="10,6" />
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Open"
                                          Click="RemoteOpenMenuItem_OnClick" />
                                <MenuItem Header="Download to Local"
                                          Click="RemoteDownloadMenuItem_OnClick" />
                                <Separator />
                                <MenuItem Header="Copy Path"
                                          Click="RemoteCopyPathMenuItem_OnClick" />
                                <MenuItem Header="Delete"
                                          Click="RemoteDeleteMenuItem_OnClick" />
                                <MenuItem Header="Refresh"
                                          Click="RemoteRefreshMenuItem_OnClick" />
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header=""
                                                    Width="52"
                                                    IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="18"
                                                   Text="{Binding EntryIcon}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*" />
                            <DataGridTextColumn Header="Type" Binding="{Binding EntryType}" Width="110" />
                            <DataGridTextColumn Header="Size" Binding="{Binding SizeText}" Width="110" />
                            <DataGridTextColumn Header="Last Write (UTC)" Binding="{Binding LastWriteTimeUtc}" Width="170" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <TextBlock x:Name="StatusTextBlock"
                   Grid.Row="2"
                   Margin="0,12,0,0"
                   Text="Ready" />
    </Grid>
</UserControl>
