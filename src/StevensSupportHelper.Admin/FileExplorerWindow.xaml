<Window x:Class="StevensSupportHelper.Admin.FileExplorerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Remote File Explorer"
        Height="560"
        Width="980"
        MinHeight="420"
        MinWidth="760">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox x:Name="PathTextBox"
                     Grid.Column="0"
                     Height="34"
                     VerticalContentAlignment="Center" />
            <Button x:Name="UpButton"
                    Grid.Column="1"
                    Margin="12,0,0,0"
                    Padding="16,8"
                    Content="Up"
                    Click="UpButton_OnClick" />
            <Button x:Name="RefreshButton"
                    Grid.Column="2"
                    Margin="12,0,0,0"
                    Padding="16,8"
                    Content="Refresh"
                    Click="RefreshButton_OnClick" />
            <Button x:Name="NewFolderButton"
                    Grid.Column="3"
                    Margin="12,0,0,0"
                    Padding="16,8"
                    Content="New Folder"
                    Click="NewFolderButton_OnClick" />
            <Button x:Name="UploadButton"
                    Grid.Column="4"
                    Margin="12,0,0,0"
                    Padding="16,8"
                    Content="Upload"
                    Click="UploadButton_OnClick" />
            <Button x:Name="DownloadButton"
                    Grid.Column="5"
                    Margin="12,0,0,0"
                    Padding="16,8"
                    Content="Download"
                    Click="DownloadButton_OnClick" />
            <Button x:Name="DeleteButton"
                    Grid.Column="6"
                    Margin="12,0,0,0"
                    Padding="16,8"
                    Content="Delete"
                    Click="DeleteButton_OnClick" />
        </Grid>

        <DataGrid x:Name="EntriesDataGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  MouseDoubleClick="EntriesDataGrid_OnMouseDoubleClick"
                  SelectionChanged="EntriesDataGrid_OnSelectionChanged"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="3*" />
                <DataGridTextColumn Header="Type" Binding="{Binding EntryType}" Width="120" />
                <DataGridTextColumn Header="Size" Binding="{Binding SizeText}" Width="120" />
                <DataGridTextColumn Header="Last Write (UTC)" Binding="{Binding LastWriteTimeUtc}" Width="200" />
                <DataGridTextColumn Header="Full Path" Binding="{Binding FullPath}" Width="4*" />
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock x:Name="StatusTextBlock"
                   Grid.Row="2"
                   Margin="0,12,0,0"
                   Text="Ready" />
    </Grid>
</Window>
