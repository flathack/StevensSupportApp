<Window x:Class="StevensSupportHelper.Admin.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hilfe"
        Height="520"
        Width="760"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="22"
                   FontWeight="SemiBold"
                   Text="Hilfe" />

        <Border Grid.Row="1"
                Margin="0,16,0,0"
                Padding="16"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold"
                               Text="Schnellstart" />
                    <TextBlock Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Text="1. In Application > Settings Server-URL, API-Key, Remote-Credentials und optional den Client-Installer-Pfad setzen." />
                    <TextBlock Margin="0,6,0,0"
                               TextWrapping="Wrap"
                               Text="2. Einen Client in der Liste auswaehlen oder per Doppelklick oeffnen." />
                    <TextBlock Margin="0,6,0,0"
                               TextWrapping="Wrap"
                               Text="3. Fuer direkte Aktionen Connect, RDP Connect, Remote Action oder Update verwenden." />

                    <TextBlock Margin="0,18,0,0"
                               FontWeight="SemiBold"
                               Text="Themes" />
                    <TextBlock Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Text="Unter View > Theme kannst du zwischen Light und Dark wechseln. Das ausgewaehlte Theme wird lokal gespeichert." />

                    <TextBlock Margin="0,18,0,0"
                               FontWeight="SemiBold"
                               Text="Client-Update" />
                    <TextBlock Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Text="Wenn fuer einen Client eine neuere lokale Version verfuegbar ist, erscheint in der Kachel der Button Update. Vor dem Start wird die aktuelle client.installer.config vom Client geladen und kann im Dialog angepasst werden." />

                    <TextBlock Margin="0,18,0,0"
                               FontWeight="SemiBold"
                               Text="Remote Actions" />
                    <TextBlock Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Text="Remote Actions laden PowerShell-Skripte aus dem konfigurierten Skriptordner. Skripte koennen vor dem Ausfuehren angepasst und direkt auf dem Client ueber WinRM gestartet werden." />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Button Grid.Row="2"
                Width="110"
                Margin="0,18,0,0"
                HorizontalAlignment="Right"
                Click="CloseButton_OnClick"
                Content="Close" />
    </Grid>
</Window>
