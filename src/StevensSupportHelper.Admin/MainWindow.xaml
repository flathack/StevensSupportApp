<Window x:Class="StevensSupportHelper.Admin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="StevensSupportHelper Admin"
        Height="900"
        Width="1560"
        MinHeight="760"
        MinWidth="1280"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid Margin="16"
          Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="_Application">
                <MenuItem Header="_Settings"
                          Click="SettingsMenuItem_OnClick" />
                <MenuItem Header="_Generate Install Package"
                          Click="GenerateInstallPackageMenuItem_OnClick" />
                <MenuItem x:Name="StartServerMenuItem"
                          Header="Start Local Server"
                          Click="StartServerButton_OnClick" />
                <Separator />
                <MenuItem Header="E_xit"
                          Click="ExitMenuItem_OnClick" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Theme">
                    <MenuItem x:Name="LightThemeMenuItem"
                              Header="_Light"
                              IsCheckable="True"
                              Click="LightThemeMenuItem_OnClick" />
                    <MenuItem x:Name="DarkThemeMenuItem"
                              Header="_Dark"
                              IsCheckable="True"
                              Click="DarkThemeMenuItem_OnClick" />
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_Help"
                          Click="HelpMenuItem_OnClick" />
                <MenuItem Header="_About"
                          Click="AboutMenuItem_OnClick" />
            </MenuItem>
            <MenuItem x:Name="ServerStatusMenuItem"
                      IsEnabled="False"
                      Header="Server: Unknown" />
        </Menu>

        <ItemsControl Grid.Row="2"
                      Margin="0,12,12,0"
                      Panel.ZIndex="50"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      IsHitTestVisible="True"
                      ItemsSource="{Binding ToastNotifications, RelativeSource={RelativeSource AncestorType=Window}}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Width="320"
                            Margin="0,0,0,10"
                            Padding="0"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Click="ToastNotificationButton_OnClick"
                            Tag="{Binding ClientId}">
                        <Border Padding="12"
                                Background="{DynamicResource PanelBackgroundBrush}"
                                BorderBrush="#7C3AED"
                                BorderThickness="1"
                                CornerRadius="10"
                                Opacity="0.96">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold"
                                           Text="{Binding Title}" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           TextWrapping="Wrap"
                                           Text="{Binding Message}" />
                            </StackPanel>
                        </Border>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TabControl x:Name="MainNavigationTabControl"
                    Grid.Row="2"
                    Background="{DynamicResource SurfaceBackgroundBrush}">
            <TabItem Header="Start">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel>
                        <TextBlock FontSize="26"
                                   FontWeight="SemiBold"
                                   Text="Clients" />
                        <Button x:Name="RefreshButton"
                                DockPanel.Dock="Right"
                                Width="120"
                                Padding="12,8"
                                Click="RefreshButton_OnClick"
                                Content="Refresh" />
                    </DockPanel>

                    <StackPanel Grid.Row="1"
                                Margin="0,14,0,0">
                        <TextBlock x:Name="HomeInfoTextBlock"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Text="Startseite mit allen Clients. Oeffne einen Client per Doppelklick oder Kontextmenue." />
                        <TextBlock Margin="0,12,0,6"
                                   FontWeight="SemiBold"
                                   Text="Support Reason" />
                        <TextBox x:Name="ReasonTextBox"
                                 Height="70"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="Remote support requested." />
                        <StackPanel x:Name="MfaPanel"
                                    Margin="0,12,0,0"
                                    Orientation="Horizontal"
                                    Visibility="Collapsed">
                            <TextBlock Margin="0,0,10,0"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Text="MFA / TOTP" />
                            <TextBox x:Name="MfaCodeTextBox"
                                     Width="220"
                                     Height="34"
                                     VerticalContentAlignment="Center"
                                     ToolTip="Aktueller TOTP-Code fuer diesen Admin-Account" />
                        </StackPanel>
                    </StackPanel>

                    <ListView x:Name="ClientsDataGrid"
                              Grid.Row="2"
                              Margin="0,14,0,0"
                              Background="{DynamicResource SurfaceBackgroundBrush}"
                              SelectionChanged="ClientsDataGrid_OnSelectionChanged"
                              MouseDoubleClick="ClientsDataGrid_OnMouseDoubleClick"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ContextMenu>
                            <ContextMenu Style="{StaticResource FlatContextMenuStyle}">
                                <ContextMenu.Resources>
                                    <Style TargetType="MenuItem"
                                           BasedOn="{StaticResource FlatContextMenuItemStyle}" />
                                    <Style TargetType="Separator"
                                           BasedOn="{StaticResource FlatContextSeparatorStyle}" />
                                </ContextMenu.Resources>
                                <MenuItem Header="Open Client Workspace"
                                          Click="OpenClientWorkspaceMenuItem_OnClick" />
                                <MenuItem Header="Request Support"
                                          Click="RequestSupportButton_OnClick" />
                                <MenuItem Header="Connect"
                                          Click="ConnectButton_OnClick" />
                                <MenuItem Header="RDP Connect"
                                          Click="RdpConnectButton_OnClick" />
                                <MenuItem Header="RustDesk Connect"
                                          Click="RustDeskConnectButton_OnClick" />
                                <Separator />
                                <MenuItem Header="PowerShell Console"
                                          Click="PowerShellButton_OnClick" />
                                <MenuItem Header="Dashboard"
                                          Click="DashboardButton_OnClick" />
                                <MenuItem Header="Files Tab"
                                          Click="FileExplorerButton_OnClick" />
                                <MenuItem Header="Tasks Tab"
                                          Click="TaskManagerButton_OnClick" />
                                <MenuItem Header="Services Tab"
                                          Click="ServicesButton_OnClick" />
                                <MenuItem Header="Software Tab"
                                          Click="SoftwareButton_OnClick" />
                                <MenuItem Header="Power Options"
                                          Click="PowerOptionsButton_OnClick" />
                                <MenuItem Header="Windows Updates"
                                          Click="WindowsUpdatesButton_OnClick" />
                                <MenuItem Header="Chat"
                                          Click="ChatButton_OnClick" />
                                <MenuItem Header="Remote Actions"
                                          Click="RemoteActionButton_OnClick" />
                                <MenuItem Header="Screenshot"
                                          Click="ScreenshotButton_OnClick" />
                                <MenuItem Header="Update Client"
                                          Click="UpdateClientButton_OnClick" />
                                <MenuItem Header="Registry Tab"
                                          Click="RegistryButton_OnClick" />
                                <Separator />
                                <MenuItem Header="Reboot"
                                          Click="RebootButton_OnClick" />
                                <MenuItem Header="Shutdown"
                                          Click="ShutdownButton_OnClick" />
                                <Separator />
                                <MenuItem Header="Edit Client Settings"
                                          Click="EditClientButton_OnClick" />
                                <MenuItem Header="Delete Client"
                                          Click="DeleteClientButton_OnClick" />
                            </ContextMenu>
                        </ListView.ContextMenu>
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Width" Value="330" />
                                <Setter Property="Height" Value="250" />
                                <Setter Property="Margin" Value="0,0,12,12" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="14"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Background="{DynamicResource SurfaceBackgroundBrush}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                                    <Setter Property="BorderBrush" Value="#15803D" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                                    <Setter Property="BorderBrush" Value="#B91C1C" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <DockPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="12"
                                                         Height="12"
                                                         Margin="0,5,10,0"
                                                         VerticalAlignment="Top">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="#B91C1C" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                                                    <Setter Property="Fill" Value="#15803D" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock FontSize="16"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding DeviceName}" />
                                            </StackPanel>
                                            <StackPanel DockPanel.Dock="Right"
                                                        HorizontalAlignment="Right">
                                                <Border HorizontalAlignment="Right"
                                                        Padding="8,3"
                                                        CornerRadius="10"
                                                        Background="#1E3A8A">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasBatteryInfo}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="White"
                                                               Text="{Binding BatteryBadgeText}" />
                                                </Border>
                                                <Border HorizontalAlignment="Right"
                                                        Margin="0,6,0,0"
                                                        Padding="8,3"
                                                        CornerRadius="10"
                                                        Background="#7C3AED">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasUnreadClientChat}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="White"
                                                               Text="{Binding ChatBadgeText}" />
                                                </Border>
                                                <Button Width="94"
                                                        Height="30"
                                                        Margin="0,8,0,0"
                                                        Padding="10,4"
                                                        Click="UpdateClientButton_OnClick"
                                                        Content="Update">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsUpdateAvailable}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>
                                        </DockPanel>

                                        <TextBlock Grid.Row="1"
                                                   Margin="0,8,0,0"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   Text="{Binding ConnectionSummary}" />

                                        <TextBlock Grid.Row="2"
                                                   Margin="0,4,0,0"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   Text="{Binding CapabilitySummary}" />

                                        <TextBlock Grid.Row="3"
                                                   Margin="0,4,0,0">
                                            <Run Text="{Binding PresenceStateText, Mode=OneWay}">
                                                <Run.Style>
                                                    <Style TargetType="Run">
                                                        <Setter Property="FontWeight" Value="Bold" />
                                                        <Setter Property="Foreground" Value="#B91C1C" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                                                <Setter Property="Foreground" Value="#15803D" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Run.Style>
                                            </Run>
                                            <Run Text=" | "
                                                 Foreground="{DynamicResource SecondaryTextBrush}" />
                                            <Run Text="{Binding LastSeenText, Mode=OneWay}"
                                                 Foreground="{DynamicResource SecondaryTextBrush}" />
                                        </TextBlock>

                                        <StackPanel Grid.Row="4"
                                                    Margin="0,8,0,0">
                                            <TextBlock Foreground="{DynamicResource SecondaryTextBrush}"
                                                       Text="{Binding SystemSummary}" />
                                            <StackPanel Margin="0,4,0,0"
                                                        Orientation="Horizontal">
                                                <TextBlock Foreground="{DynamicResource SecondaryTextBrush}"
                                                           Text="{Binding UptimeSummary}" />
                                                <TextBlock Margin="10,0,0,0"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           Text="{Binding MemorySummary}" />
                                            </StackPanel>
                                            <Grid Margin="0,5,0,0"
                                                  Width="164"
                                                  Height="8"
                                                  HorizontalAlignment="Left">
                                                <Grid.Style>
                                                    <Style TargetType="Grid">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasMemoryInfo}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Grid.Style>
                                                <Border CornerRadius="4"
                                                        Background="#233047" />
                                                <Border Width="{Binding MemoryBarWidth}"
                                                        HorizontalAlignment="Left"
                                                        CornerRadius="4"
                                                        Background="#10B981" />
                                            </Grid>
                                            <TextBlock FontWeight="SemiBold"
                                                       Margin="0,8,0,0"
                                                       Text="{Binding ActiveSessionText}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Text="{Binding PendingSupportRequestText}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="#B45309"
                                                       Text="{Binding UpdateSummary}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="#A78BFA"
                                                       Text="{Binding ChatSummary}" />
                                            <ItemsControl Margin="0,8,0,0"
                                                          ItemsSource="{Binding DiskUsages}">
                                                <ItemsControl.Style>
                                                    <Style TargetType="ItemsControl">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasDiskUsage}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ItemsControl.Style>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="0,0,0,6">
                                                            <DockPanel LastChildFill="False">
                                                                <TextBlock FontSize="11"
                                                                           FontWeight="SemiBold"
                                                                           Text="{Binding UsageSummary}" />
                                                                <TextBlock Margin="8,0,0,0"
                                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                                           Text="{Binding CapacitySummary}" />
                                                            </DockPanel>
                                                            <Grid Margin="0,3,0,0"
                                                                  Width="164"
                                                                  Height="8"
                                                                  HorizontalAlignment="Left">
                                                                <Border CornerRadius="4"
                                                                        Background="#233047" />
                                                                <Border Width="{Binding UsedBarWidth}"
                                                                        HorizontalAlignment="Left"
                                                                        CornerRadius="4"
                                                                        Background="#3B82F6" />
                                                            </Grid>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>

                                        <StackPanel Grid.Row="5">
                                            <TextBlock Margin="0,6,0,0"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       Text="{Binding Notes}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </TabItem>

            <TabItem Header="Audit">
                <ListView x:Name="AuditListView"
                          Margin="12"
                          Background="{DynamicResource SurfaceBackgroundBrush}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Time (UTC)" Width="180" DisplayMemberBinding="{Binding CreatedAtUtc}" />
                            <GridViewColumn Header="Type" Width="150" DisplayMemberBinding="{Binding EventType}" />
                            <GridViewColumn Header="Device" Width="180" DisplayMemberBinding="{Binding DeviceName}" />
                            <GridViewColumn Header="Actor" Width="160" DisplayMemberBinding="{Binding Actor}" />
                            <GridViewColumn Header="Message" Width="760" DisplayMemberBinding="{Binding Message}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </TabItem>

            <TabItem Header="Logs">
                <ListView x:Name="LogListView"
                          Margin="12"
                          Background="{DynamicResource SurfaceBackgroundBrush}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Time (UTC)" Width="180" DisplayMemberBinding="{Binding CreatedAtUtc}" />
                            <GridViewColumn Header="Level" Width="100" DisplayMemberBinding="{Binding Level}" />
                            <GridViewColumn Header="Message" Width="820" DisplayMemberBinding="{Binding Message}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </TabItem>
        </TabControl>

        <TextBlock x:Name="StatusTextBlock"
                   Grid.Row="3"
                   Margin="0,12,0,0"
                   Text="Ready" />
    </Grid>
</Window>
