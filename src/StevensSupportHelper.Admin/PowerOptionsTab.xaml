<UserControl x:Class="StevensSupportHelper.Admin.PowerOptionsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel>
            <TextBlock x:Name="SummaryTextBlock"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       Text="Power plans" />
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        DockPanel.Dock="Right">
                <Button Margin="0,0,10,0"
                        Width="90"
                        Click="RefreshButton_OnClick"
                        Content="Refresh" />
                <Button x:Name="ActivateButton"
                        Width="130"
                        Click="ActivateButton_OnClick"
                        Content="Activate Plan" />
            </StackPanel>
        </DockPanel>

        <DataGrid x:Name="PlansDataGrid"
                  Grid.Row="1"
                  Margin="0,12,0,0"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Plan" Binding="{Binding Name}" Width="2*" />
                <DataGridTextColumn Header="Guid" Binding="{Binding Guid}" Width="2*" />
                <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="90" />
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock x:Name="StatusTextBlock"
                   Grid.Row="2"
                   Margin="0,12,0,0"
                   Text="Ready" />
    </Grid>
</UserControl>
