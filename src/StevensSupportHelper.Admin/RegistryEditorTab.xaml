<UserControl x:Class="StevensSupportHelper.Admin.RegistryEditorTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:StevensSupportHelper.Admin.Models">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox x:Name="RegistryPathTextBox"
                     Height="34"
                     VerticalContentAlignment="Center"
                     Text="Registry::HKEY_LOCAL_MACHINE\SOFTWARE" />
            <Button x:Name="RefreshButton"
                    Grid.Column="1"
                    Margin="12,0,0,0"
                    Padding="14,8"
                    Content="Refresh"
                    Click="RefreshButton_OnClick" />
            <Button x:Name="UpButton"
                    Grid.Column="2"
                    Margin="12,0,0,0"
                    Padding="14,8"
                    Content="Up"
                    Click="UpButton_OnClick" />
            <Button x:Name="NewStringButton"
                    Grid.Column="3"
                    Margin="12,0,0,0"
                    Padding="14,8"
                    Content="New String"
                    Click="NewStringButton_OnClick" />
            <Button x:Name="DeleteButton"
                    Grid.Column="4"
                    Margin="12,0,0,0"
                    Padding="14,8"
                    Content="Delete Value"
                    Click="DeleteButton_OnClick" />
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TreeView x:Name="RegistryTreeView"
                      SelectedItemChanged="RegistryTreeView_OnSelectedItemChanged">
                <TreeView.Resources>
                    <HierarchicalDataTemplate DataType="{x:Type models:RegistryTreeNode}"
                                              ItemsSource="{Binding Children}">
                        <TextBlock Text="{Binding Name}" />
                    </HierarchicalDataTemplate>
                </TreeView.Resources>
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                        <EventSetter Event="Expanded" Handler="RegistryTreeItem_OnExpanded" />
                    </Style>
                </TreeView.ItemContainerStyle>
            </TreeView>

            <DataGrid x:Name="ValuesDataGrid"
                      Grid.Column="2"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionChanged="ValuesDataGrid_OnSelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding FullName}" Width="180" />
                    <DataGridTextColumn Header="Kind" Binding="{Binding Kind}" Width="120" />
                    <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <TextBlock x:Name="StatusTextBlock"
                   Grid.Row="2"
                   Margin="0,12,0,0"
                   Text="Ready" />
    </Grid>
</UserControl>
