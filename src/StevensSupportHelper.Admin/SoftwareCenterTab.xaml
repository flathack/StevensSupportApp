<UserControl x:Class="StevensSupportHelper.Admin.SoftwareCenterTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ComboBox x:Name="CatalogComboBox"
                      Height="34"
                      VerticalContentAlignment="Center"
                      DisplayMemberPath="DisplayName" />
            <TextBox x:Name="SearchTextBox"
                     Grid.Column="1"
                     Margin="12,0,0,0"
                     Height="34"
                     VerticalContentAlignment="Center"
                     TextChanged="SearchTextBox_OnTextChanged" />
            <Button x:Name="InstallButton"
                    Grid.Column="2"
                    Margin="12,0,0,0"
                    Padding="14,8"
                    Content="Install Selected"
                    Click="InstallButton_OnClick" />
            <Button x:Name="UninstallButton"
                    Grid.Column="3"
                    Margin="12,0,0,0"
                    Padding="14,8"
                    Content="Silent Uninstall"
                    Click="UninstallButton_OnClick" />
            <Button x:Name="RefreshButton"
                    Grid.Column="4"
                    Margin="12,0,0,0"
                    Padding="14,8"
                    Content="Refresh"
                    Click="RefreshButton_OnClick" />
        </Grid>

        <DataGrid x:Name="SoftwareDataGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="SoftwareDataGrid_OnSelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Software" Binding="{Binding DisplayName}" Width="2*" />
                <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="120" />
                <DataGridTextColumn Header="Publisher" Binding="{Binding Publisher}" Width="2*" />
                <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="100" />
                <DataGridTextColumn Header="Quiet Uninstall" Binding="{Binding QuietUninstallCommand}" Width="2*" />
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock x:Name="StatusTextBlock"
                   Grid.Row="2"
                   Margin="0,12,0,0"
                   Text="Ready" />
    </Grid>
</UserControl>
