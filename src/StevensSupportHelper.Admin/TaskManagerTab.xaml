<UserControl x:Class="StevensSupportHelper.Admin.TaskManagerTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="260" />
            </Grid.ColumnDefinitions>

            <Button x:Name="RefreshButton"
                    Padding="16,8"
                    Content="Refresh"
                    Click="RefreshButton_OnClick" />
            <Button x:Name="StartProcessButton"
                    Grid.Column="2"
                    Padding="16,8"
                    Content="Start Process"
                    Click="StartProcessButton_OnClick" />
            <Button x:Name="KillProcessButton"
                    Grid.Column="4"
                    Padding="16,8"
                    Content="Kill Process"
                    Click="KillProcessButton_OnClick" />
            <TextBox x:Name="SearchTextBox"
                     Grid.Column="6"
                     Height="34"
                     VerticalContentAlignment="Center"
                     TextChanged="SearchTextBox_OnTextChanged" />
        </Grid>

        <UniformGrid Grid.Row="1"
                     Margin="0,0,0,12"
                     Columns="4">
            <Border Margin="0,0,10,0"
                    Padding="10"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Background="{DynamicResource PanelBackgroundBrush}">
                <StackPanel>
                    <TextBlock Text="CPU"
                               Foreground="{DynamicResource SecondaryTextBrush}" />
                    <TextBlock x:Name="CpuTextBlock"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Text="0 %" />
                </StackPanel>
            </Border>
            <Border Margin="0,0,10,0"
                    Padding="10"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Background="{DynamicResource PanelBackgroundBrush}">
                <StackPanel>
                    <TextBlock Text="RAM"
                               Foreground="{DynamicResource SecondaryTextBrush}" />
                    <TextBlock x:Name="MemoryTextBlock"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Text="0 / 0 GB" />
                </StackPanel>
            </Border>
            <Border Margin="0,0,10,0"
                    Padding="10"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Background="{DynamicResource PanelBackgroundBrush}">
                <StackPanel>
                    <TextBlock Text="RAM Usage"
                               Foreground="{DynamicResource SecondaryTextBrush}" />
                    <TextBlock x:Name="MemoryPercentTextBlock"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Text="0 %" />
                </StackPanel>
            </Border>
            <Border Padding="10"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Background="{DynamicResource PanelBackgroundBrush}">
                <StackPanel>
                    <TextBlock Text="Processes"
                               Foreground="{DynamicResource SecondaryTextBrush}" />
                    <TextBlock x:Name="ProcessCountTextBlock"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Text="0" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <DataGrid x:Name="ProcessesDataGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="ProcessesDataGrid_OnSelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="PID" Binding="{Binding Id}" Width="80" />
                <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="2*" />
                <DataGridTextColumn Header="Window Title" Binding="{Binding MainWindowTitle}" Width="3*" />
                <DataGridTextColumn Header="CPU (s)" Binding="{Binding CpuSeconds}" Width="90" />
                <DataGridTextColumn Header="RAM (MB)" Binding="{Binding WorkingSetMb}" Width="100" />
                <DataGridTextColumn Header="Start (UTC)" Binding="{Binding StartTimeUtc}" Width="180" />
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock x:Name="StatusTextBlock"
                   Grid.Row="3"
                   Margin="0,12,0,0"
                   Text="Ready" />
    </Grid>
</UserControl>
