<Window x:Class="StevensSupportHelper.Admin.TaskManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Remote Task Manager"
        Height="560"
        Width="920"
        MinHeight="420"
        MinWidth="720">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Margin="0,0,0,12"
                    Orientation="Horizontal">
            <Button x:Name="RefreshButton"
                    Padding="16,8"
                    Content="Refresh"
                    Click="RefreshButton_OnClick" />
            <Button x:Name="StartProcessButton"
                    Margin="12,0,0,0"
                    Padding="16,8"
                    Content="Start Process"
                    Click="StartProcessButton_OnClick" />
            <Button x:Name="KillProcessButton"
                    Margin="12,0,0,0"
                    Padding="16,8"
                    Content="Kill Process"
                    Click="KillProcessButton_OnClick" />
        </StackPanel>

        <DataGrid x:Name="ProcessesDataGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="ProcessesDataGrid_OnSelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="PID" Binding="{Binding Id}" Width="90" />
                <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="2*" />
                <DataGridTextColumn Header="Window Title" Binding="{Binding MainWindowTitle}" Width="3*" />
                <DataGridTextColumn Header="CPU (s)" Binding="{Binding CpuSeconds}" Width="100" />
                <DataGridTextColumn Header="RAM (MB)" Binding="{Binding WorkingSetMb}" Width="110" />
                <DataGridTextColumn Header="Start (UTC)" Binding="{Binding StartTimeUtc}" Width="180" />
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock x:Name="StatusTextBlock"
                   Grid.Row="2"
                   Margin="0,12,0,0"
                   Text="Ready" />
    </Grid>
</Window>
