<UserControl x:Class="StevensSupportHelper.Admin.WindowsUpdatesTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel>
            <TextBlock x:Name="SummaryTextBlock"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       Text="Windows updates" />
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        DockPanel.Dock="Right">
                <Button Margin="0,0,10,0"
                        Width="90"
                        Click="RefreshButton_OnClick"
                        Content="Refresh" />
                <Button x:Name="InstallButton"
                        Width="170"
                        Click="InstallButton_OnClick"
                        Content="Install Available" />
            </StackPanel>
        </DockPanel>

        <DataGrid x:Name="UpdatesDataGrid"
                  Grid.Row="1"
                  Margin="0,12,0,0"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="3*" />
                <DataGridTextColumn Header="KB" Binding="{Binding KbArticleIds}" Width="120" />
                <DataGridTextColumn Header="Categories" Binding="{Binding Categories}" Width="2*" />
                <DataGridCheckBoxColumn Header="Downloaded" Binding="{Binding IsDownloaded}" Width="100" />
                <DataGridTextColumn Header="Max MB" Binding="{Binding MaxDownloadSizeBytes}" Width="100" />
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock x:Name="StatusTextBlock"
                   Grid.Row="2"
                   Margin="0,12,0,0"
                   Text="Ready" />
    </Grid>
</UserControl>
