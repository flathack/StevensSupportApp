@page
@model StevensSupportHelper.AdminWeb.Pages.AuditModel
@{
    ViewData["Title"] = "Audit Log";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Audit Log - StevensSupportHelper Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/Dashboard">StevensSupportHelper</a>
            <div>
                <a class="btn btn-outline-light btn-sm" href="/Dashboard">Dashboard</a>
                <a class="btn btn-outline-light btn-sm" href="/Audit">Audit</a>
            </div>
        </div>
    </nav>

    <main class="container mt-4">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Audit Log</h5>
            </div>
            @if (Model.Entries.Count == 0)
            {
                <div class="card-body text-center text-muted">
                    No audit entries found.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Time</th>
                                <th>Event</th>
                                <th>Device</th>
                                <th>Actor</th>
                                <th>Message</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var entry in Model.Entries.OrderByDescending(e => e.CreatedAtUtc))
                            {
                                <tr>
                                    <td>@entry.CreatedAtUtc.ToString("g")</td>
                                    <td><span class="badge bg-info">@entry.EventType</span></td>
                                    <td>@entry.DeviceName</td>
                                    <td>@entry.Actor</td>
                                    <td>@entry.Message</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </main>
</body>
</html>