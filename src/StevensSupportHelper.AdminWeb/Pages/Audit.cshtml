@page
@model StevensSupportHelper.AdminWeb.Pages.AuditModel
@{
    ViewData["Title"] = "Audit-Protokoll";
    ViewData["Subtitle"] = "Chronologischer Überblick über Supportaktionen, Sitzungen und Operatorenaktivität";
}

@section HeaderActions {
    <a class="shell-btn-outline" asp-page="/Dashboard">Zurück zum Dashboard</a>
}

<section class="surface-card">
    <div class="surface-card-header">
        <div>
            <div class="eyebrow">Prüfspur</div>
            <h2 class="section-title">Letzte Aktivitäten</h2>
            <p class="section-subtitle">Wie ein Einsatzprotokoll aufgebaut, damit Aktionen schnell erfasst werden können.</p>
        </div>
    </div>
    <div class="surface-card-body">
        @if (Model.Entries.Count == 0)
        {
            <div class="empty-state">Es wurden noch keine Audit-Einträge gefunden.</div>
        }
        else
        {
            <div class="shell-table-wrap">
                <table class="shell-table">
                    <thead>
                        <tr>
                            <th>Zeit</th>
                            <th>Ereignis</th>
                            <th>Gerät</th>
                            <th>Akteur</th>
                            <th>Nachricht</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in Model.Entries.OrderByDescending(e => e.CreatedAtUtc))
                        {
                            <tr>
                                <td>@entry.CreatedAtUtc.ToLocalTime().ToString("g")</td>
                                <td><span class="status-badge-shell offline">@entry.EventType</span></td>
                                <td>@entry.DeviceName</td>
                                <td>@entry.Actor</td>
                                <td>@entry.Message</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>
