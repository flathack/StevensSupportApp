@page "/clients/details"
@model StevensSupportHelper.AdminWeb.Pages.Clients.DetailsModel
@{
    ViewData["Title"] = "Client Details";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Client Details - StevensSupportHelper Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/Dashboard">StevensSupportHelper</a>
            <a class="btn btn-outline-light btn-sm" href="/Dashboard">Back to Dashboard</a>
        </div>
    </nav>

    <main class="container mt-4">
        @if (Model.Client is null)
        {
            <div class="alert alert-warning">Client not found.</div>
            return;
        }

        <!-- Action Messages -->
        @if (!string.IsNullOrEmpty(Model.ActionMessage))
        {
            <div class="alert @(Model.IsActionError ? "alert-danger" : "alert-success")">
                @Model.ActionMessage
            </div>
        }

        <!-- Client Info -->
        <div class="row mb-4">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">@Model.Client.DeviceName</h5>
                    </div>
                    <div class="card-body">
                        <dl class="row">
                            <dt class="col-sm-4">Machine</dt>
                            <dd class="col-sm-8">@Model.Client.MachineName</dd>

                            <dt class="col-sm-4">User</dt>
                            <dd class="col-sm-8">@Model.Client.CurrentUser</dd>

                            <dt class="col-sm-4">Status</dt>
                            <dd class="col-sm-8">
                                @if (Model.Client.IsOnline)
                                {
                                    <span class="badge bg-success">Online</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Offline</span>
                                }
                            </dd>

                            <dt class="col-sm-4">Agent Version</dt>
                            <dd class="col-sm-8">@Model.Client.AgentVersion</dd>

                            <dt class="col-sm-4">OS</dt>
                            <dd class="col-sm-8">@Model.Client.OsDescription</dd>

                            <dt class="col-sm-4">Last Seen</dt>
                            <dd class="col-sm-8">@Model.Client.LastSeenAtUtc.ToString("g")</dd>

                            <dt class="col-sm-4">Notes</dt>
                            <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.Client.Notes) ? "-" : Model.Client.Notes)</dd>
                        </dl>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <!-- Active Session -->
                @if (Model.Client.ActiveSession is not null)
                {
                    <div class="card mb-4">
                        <div class="card-header bg-warning">
                            <h5 class="mb-0">Active Support Session</h5>
                        </div>
                        <div class="card-body">
                            <p><strong>Admin:</strong> @Model.Client.ActiveSession.AdminDisplayName</p>
                            <p><strong>Channel:</strong> @Model.Client.ActiveSession.Channel</p>
                            <p><strong>Started:</strong> @Model.Client.ActiveSession.StartedAtUtc.ToString("g")</p>
                            <form method="post" asp-page-handler="EndSession">
                                <button type="submit" class="btn btn-danger">End Session</button>
                            </form>
                        </div>
                    </div>
                }

                <!-- Create Support Request -->
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Request Support</h5>
                    </div>
                    <div class="card-body">
                        <form method="post" asp-page-handler="Support">
                            <div class="mb-3">
                                <label class="form-label">Channel</label>
                                <select class="form-select" asp-for="PreferredChannel">
                                    <option value="RustDesk">RustDesk</option>
                                    <option value="RDP">RDP</option>
                                    <option value="WinRM">WinRM</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Reason</label>
                                <textarea class="form-control" asp-for="SupportReason" rows="3" required></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary">Request Support</button>
                        </form>
                    </div>
                </div>

                <!-- Remote Actions -->
                <div class="card mt-4">
                    <div class="card-header">
                        <h5 class="mb-0">Remote Actions</h5>
                    </div>
                    <div class="card-body">
                        @if (Model.RemoteActions.Count == 0)
                        {
                            <p class="text-muted">No remote actions available.</p>
                        }
                        else
                        {
                            <form method="post" asp-page-handler="ExecuteScript">
                                <div class="mb-3">
                                    <label class="form-label">Select Script</label>
                                    <select class="form-select" asp-for="SelectedScript">
                                        <option value="">-- Select a script --</option>
                                        @foreach (var action in Model.RemoteActions)
                                        {
                                            <option value="@action.Name">@action.Name - @action.Description</option>
                                        }
                                    </select>
                                </div>
                                <button type="submit" class="btn btn-warning">Execute Script</button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    </main>
</body>
</html>