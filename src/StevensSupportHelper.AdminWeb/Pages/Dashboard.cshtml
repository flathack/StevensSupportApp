@page
@model StevensSupportHelper.AdminWeb.Pages.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard - StevensSupportHelper Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow">
        <div class="container-fluid">
            <a class="navbar-brand" href="#">StevensSupportHelper</a>
            <div class="d-flex">
                <span class="navbar-text me-3">Welcome, @Model.DisplayName</span>
                <form method="post" asp-page-handler="Logout" class="d-inline">
                    <button type="submit" class="btn btn-outline-light btn-sm">Logout</button>
                </form>
            </div>
        </div>
    </nav>

    <main class="container mt-4">
        <div class="row mb-4">
            <div class="col-md-4">
                <div class="card">
                    <div class="card-body">
                        <h6 class="card-subtitle mb-2 text-muted">Total Clients</h6>
                        <h2 class="card-title mb-0">@Model.Clients.Count</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card">
                    <div class="card-body">
                        <h6 class="card-subtitle mb-2 text-muted">Online</h6>
                        <h2 class="card-title mb-0 text-success">@Model.OnlineCount</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card">
                    <div class="card-body">
                        <h6 class="card-subtitle mb-2 text-muted">Offline</h6>
                        <h2 class="card-title mb-0 text-muted">@Model.OfflineCount</h2>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Connected Clients</h5>
            </div>
            @if (Model.Clients.Count == 0)
            {
                <div class="card-body text-center text-muted">
                    No clients connected yet.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Device</th>
                                <th>Machine</th>
                                <th>User</th>
                                <th>Status</th>
                                <th>Version</th>
                                <th>Last Seen</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var client in Model.Clients)
                            {
                                <tr>
                                    <td>@client.DeviceName</td>
                                    <td>@client.MachineName</td>
                                    <td>@client.CurrentUser</td>
                                    <td>
                                        @if (client.IsOnline)
                                        {
                                            <span class="badge bg-success">Online</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Offline</span>
                                        }
                                    </td>
                                    <td>@client.AgentVersion</td>
                                    <td>@client.LastSeenAtUtc.ToString("g")</td>
                                    <td>
                                        <a href="/clients/details?id=@client.ClientId" class="btn btn-sm btn-outline-primary">Details</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </main>
</body>
</html>