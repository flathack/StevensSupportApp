@page
@model StevensSupportHelper.AdminWeb.Pages.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
    ViewData["Subtitle"] = "Live-Überblick über Clients, Sitzungen und schnelle Aktionen";
}

@section HeaderActions {
    <a class="shell-btn-outline" asp-page="/Audit">Audit öffnen</a>
    <a class="shell-btn" asp-page="/Settings">Server-Einstellungen</a>
}

<div class="stats-grid mb-4">
    <div class="metric-card surface-card">
        <div class="metric-label">Clients gesamt</div>
        <div class="metric-value">@Model.Clients.Count</div>
        <div class="metric-note">Registrierte Geräte im Supportbestand</div>
    </div>
    <div class="metric-card surface-card">
        <div class="metric-label">Online</div>
        <div class="metric-value text-success">@Model.OnlineCount</div>
        <div class="metric-note">Bereit für Support oder Remote-Aktionen</div>
    </div>
    <div class="metric-card surface-card">
        <div class="metric-label">Offline</div>
        <div class="metric-value text-secondary">@Model.OfflineCount</div>
        <div class="metric-note">Benötigen späteren Follow-up oder Reconnect</div>
    </div>
</div>

<section class="surface-card">
    <div class="surface-card-header">
        <div>
            <div class="eyebrow">Clientübersicht</div>
            <h2 class="section-title">Verwaltete Clients</h2>
            <p class="section-subtitle">Gerätestatus, Aktivität und schneller Einstieg in die Verwaltung.</p>
        </div>
    </div>
    <div class="surface-card-body">
        @if (Model.IsUsingDemoClients)
        {
            <div class="alert alert-info">
                Demo-Clients werden aktuell bewusst angezeigt. Sobald echte Clients online sind, wechselt das Dashboard automatisch zurück in den Live-Betrieb.
                <form method="post" asp-page-handler="DisableDemo" class="d-inline-block ms-3">
                    <button type="submit" class="shell-btn-outline">Demo-Modus beenden</button>
                </form>
            </div>
        }
        @if (Model.Clients.Count == 0)
        {
            <div class="empty-state">Es wurden noch keine Clients gemeldet. Sobald sich Agenten registrieren, erscheinen sie hier.</div>
            @if (Model.CanEnableDemoMode)
            {
                <form method="post" asp-page-handler="EnableDemo" class="mt-3">
                    <button type="submit" class="shell-btn">Demo-Modus mit Beispiel-Clients starten</button>
                </form>
            }
        }
        else
        {
            <div class="shell-table-wrap">
                <table class="shell-table">
                    <thead>
                        <tr>
                            <th>Gerät</th>
                            <th>Rechner</th>
                            <th>Benutzer</th>
                            <th>Status</th>
                            <th>Version</th>
                            <th>Zuletzt gesehen</th>
                            <th>Schnellaktionen</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var client in Model.Clients.OrderByDescending(c => c.IsOnline).ThenBy(c => c.DeviceName))
                        {
                            <tr>
                                <td><strong>@client.DeviceName</strong></td>
                                <td>@client.MachineName</td>
                                <td>@client.CurrentUser</td>
                                <td>
                                    <span class="status-badge-shell @(client.IsOnline ? "online" : "offline")">
                                        @(client.IsOnline ? "Online" : "Offline")
                                    </span>
                                </td>
                                <td>@client.AgentVersion</td>
                                <td>@client.LastSeenAtUtc.ToLocalTime().ToString("g")</td>
                                <td>
                                    <div class="action-row">
                                        <a class="shell-btn-outline" asp-page="/Clients/Details" asp-route-id="@client.ClientId">Öffnen</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>
