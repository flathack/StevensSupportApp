@page
@model ErrorModel
@{
    ViewData["Title"] = "Fehler";
    ViewData["Subtitle"] = "Ein unerwartetes Problem hat die aktuelle Aktion unterbrochen";
}

<section class="surface-card">
    <div class="surface-card-header">
        <div>
            <div class="eyebrow">Fehler</div>
            <h2 class="section-title">Anfrage fehlgeschlagen</h2>
        </div>
    </div>
    <div class="surface-card-body">
        <div class="alert alert-danger">Beim Verarbeiten der Anfrage ist ein unerwarteter Fehler aufgetreten.</div>
        @if (Model.ShowRequestId)
        {
            <p><strong>Anfrage-ID:</strong> <code>@Model.RequestId</code></p>
        }
        <div class="shell-panel-muted">
            Im Entwicklungsmodus werden detaillierte Ausnahmen angezeigt. In produktiven Systemen sollten Details deaktiviert bleiben und stattdessen die Logs geprüft werden.
        </div>
    </div>
</section>
