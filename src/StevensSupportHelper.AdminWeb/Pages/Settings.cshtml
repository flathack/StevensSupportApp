@page
@model StevensSupportHelper.AdminWeb.Pages.SettingsModel
@{
    ViewData["Title"] = "Einstellungen";
    ViewData["Subtitle"] = "Serverprofil, Schnellzugriffe und Konfigurationspunkte für den Supportbetrieb";
}

<div class="cards-grid two-col">
    <section class="surface-card">
        <div class="surface-card-header">
            <div>
                <div class="eyebrow">Überblick</div>
                <h2 class="section-title">Plattformübersicht</h2>
            </div>
        </div>
        <div class="surface-card-body">
            <div class="shell-panel-muted">
                <strong>StevensSupportHelper Web Admin</strong>
                <div class="mt-2 text-muted">Browserbasierte Steuerzentrale für Supportsitzungen, Audit-Transparenz und Client-Operationen.</div>
            </div>
            <div class="mt-3 detail-list">
                <dt>Laufzeit</dt>
                <dd>.NET 10 Razor Pages</dd>
                <dt>Ziel</dt>
                <dd>Fernsupport und Clientverwaltung</dd>
                <dt>Modus</dt>
                <dd>Web-Administration</dd>
            </div>
        </div>
    </section>

    <section class="surface-card">
        <div class="surface-card-header">
            <div>
                <div class="eyebrow">Navigation</div>
                <h2 class="section-title">Schnellzugriff</h2>
            </div>
        </div>
        <div class="surface-card-body">
            <div class="action-row">
                <a class="shell-btn" asp-page="/Dashboard">Client-Dashboard</a>
                <a class="shell-btn-outline" asp-page="/Users">Benutzerverwaltung</a>
                <a class="shell-btn-outline" asp-page="/Audit">Audit-Protokoll</a>
            </div>
            <div class="shell-panel-muted mt-3">
                Dieser Bereich ist für Serverkonfiguration, API-Key-Verwaltung, Aufbewahrungsregeln und Betriebsrichtlinien vorbereitet.
            </div>
        </div>
    </section>
</div>
