@page
@model StevensSupportHelper.AdminWeb.Pages.SettingsModel
@{
    ViewData["Title"] = "Settings";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Settings - StevensSupportHelper Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/Dashboard">StevensSupportHelper</a>
            <div>
                <a class="btn btn-outline-light btn-sm" href="/Dashboard">Dashboard</a>
                <a class="btn btn-outline-light btn-sm" href="/Audit">Audit</a>
                <a class="btn btn-outline-light btn-sm" href="/Settings">Settings</a>
            </div>
        </div>
    </nav>

    <main class="container mt-4">
        <div class="row">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">About</h5>
                    </div>
                    <div class="card-body">
                        <h4>StevensSupportHelper</h4>
                        <p class="text-muted">Web Admin Interface</p>
                        <p>Version 1.0.0</p>
                        <hr />
                        <p class="mb-0">
                            This is the web-based administration interface for StevensSupportHelper.
                            Manage clients, request support sessions, and view audit logs.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Quick Links</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-grid gap-2">
                            <a class="btn btn-primary" href="/Dashboard">Client Dashboard</a>
                            <a class="btn btn-secondary" href="/Audit">Audit Log</a>
                            <a class="btn btn-info" href="/" target="_blank">API Docs (placeholder)</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</body>
</html>