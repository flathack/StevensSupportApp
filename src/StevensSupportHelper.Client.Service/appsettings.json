{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "StevensSupportHelper": {
    "ServerBaseUrl": "http://localhost:5000",
    "DeviceName": "Default Windows Client",
    "ConsentRequired": true,
    "AutoApproveSupportRequests": false,
    "AllowSupportAtLogonScreen": true,
    "TailscaleConnected": false,
    "TailscaleIpAddresses": [],
    "AutoDetectTailscaleIps": true,
    "AutoDetectRustDeskId": true,
    "RustDeskId": "",
    "HeartbeatIntervalSeconds": 15,
    "RegistrationSharedKey": "change-me-registration-key",
    "ManagedFilesRoot": "%ProgramData%\\StevensSupportHelper\\ManagedFiles",
    "MaxTransferBytes": 5242880,
    "UpdateManifestUrl": "",
    "UpdateChannel": "stable",
    "UpdateCheckIntervalMinutes": 360,
    "UpdatesRoot": "%ProgramData%\\StevensSupportHelper\\Updates"
  }
}
